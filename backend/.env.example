KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=optional_only_if_enabled_in_kakao_console
JWT_SECRET=change_this_to_a_long_random_string

# Comma-separated allowed origins. dev only: http://localhost:5173
# prod: http://localhost:5173,https://your-frontend.web.app
CORS_ORIGIN=http://localhost:5173

# PORT is auto-injected by Cloud Run (8080). Local dev defaults to 3000 if unset.
# PORT=3001
